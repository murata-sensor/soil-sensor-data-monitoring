# Vite env (example only — never commit a real .env)
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxxxx.apps.googleusercontent.com
VITE_REGISTRY_SPREADSHEET_ID=replace-with-your-registry-spreadsheet-id
VITE_GAS_ADMIN_URL=https://script.google.com/macros/s/XXXX/exec
# VITE_GAS_PROXY_URL: Registry を全ユーザに直接共有しない場合は必須。
# accessMode=proxy のソースを使う場合も必要。
VITE_GAS_PROXY_URL=https://script.google.com/macros/s/XXXX/exec

# ローカル開発時は / のままでOK、GitHub Pages は /soil-sensor-data-monitoring/
VITE_BASE_PATH=/
